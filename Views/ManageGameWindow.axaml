<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OptiscalerClient"
        xmlns:converters="clr-namespace:OptiscalerClient.Converters"
        mc:Ignorable="d"
        x:Class="OptiscalerClient.Views.ManageGameWindow"
        Title="{DynamicResource TxtManageGameWindow}"
        MinHeight="600" Width="1140"
        SizeToContent="Height"
        SystemDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <Window.Resources>
        <converters:BoolToVisibilityConverter  x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter  x:Key="NullToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter  x:Key="InverseBoolToVisibilityConverter" Invert="True"/>
        <converters:MultiplyConverter x:Key="MultiplyConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.ImageCard">
            <Setter Property="CornerRadius" Value="{StaticResource RadiusLarge}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BrBorderSubtle}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource BrBgCard}"/>
        </Style>
        <Style Selector="Border.ImageOverlay">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Background" Value="#A0000000"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.ImageCard:pointerover Border.ImageOverlay">
            <Setter Property="Opacity" Value="1"/>
        </Style>

        <Style Selector="Button.InvisibleBtn">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.InvisibleBtn:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.InvisibleBtn:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="Button.IconBtn">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Styles>

    <Panel Margin="12" Name="RootPanel" Opacity="0">
        <Border CornerRadius="12"
                Background="{StaticResource BrBgBase}"
                BoxShadow="0 8 32 0 #80000000"
                BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="1">
            <Grid ColumnDefinitions="3*,7*" RowDefinitions="*">
                <!-- LEFT COLUMN -->
                <Grid Grid.Column="0" Margin="16" RowDefinitions="*,Auto">
                    <StackPanel Grid.Row="0" Spacing="12">
                    <Border Classes="ImageCard"
                            HorizontalAlignment="Stretch"
                            Height="{Binding Bounds.Width, RelativeSource={RelativeSource Self}, Converter={StaticResource MultiplyConverter}, ConverterParameter=1.4}"
                            MaxWidth="320"
                            MaxHeight="460"
                            ClipToBounds="True">
                            <Grid>
                                <Image Name="ImgGameCover" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Border Classes="ImageOverlay">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                        <TextBlock Text="&#xF493;"
                                                   FontFamily="{StaticResource FontIcons}"
                                                   FontSize="22"
                                                   Foreground="{StaticResource BrTextPrimary}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource TxtEditImage}"
                                                   Foreground="{StaticResource BrTextPrimary}"
                                                   FontSize="{StaticResource FontSizeBody}"/>
                                    </StackPanel>
                                </Border>
                                <Button Name="BtnEditImage" Classes="InvisibleBtn" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Click="BtnEditImage_Click"/>
                            </Grid>
                        </Border>

                        <StackPanel Spacing="8">
                            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                                <TextBlock Name="TxtGameName"
                                           Text="Game Name"
                                           FontSize="{StaticResource FontSizeSubtitle}"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource BrTextPrimary}"
                                           VerticalAlignment="Center"/>

                                <TextBox Name="TxtGameNameEdit"
                                         IsVisible="False"
                                         Margin="0,0,8,0"
                                         VerticalAlignment="Center"/>

                                <Button Grid.Column="1"
                                        Name="BtnEditTitle"
                                        Classes="BtnBase"
                                        Padding="10,6"
                                        Click="BtnEditTitle_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="&#xF3DD;"
                                                   FontFamily="{StaticResource FontIcons}"
                                                   FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Path & Open Folder bottom aligned -->
                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
                        <TextBlock Name="TxtInstallPath"
                                   Grid.Column="0"
                                   Text=""
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource BrTextSecondary}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   MaxWidth="260"/>

                        <Button Grid.Column="1"
                                Name="BtnOpenFolder"
                                Classes="BtnBase"
                                Padding="10,6"
                                ToolTip.Tip="{DynamicResource TxtOpenFolder}"
                                VerticalAlignment="Center"
                                Click="BtnOpenFolder_Click">
                            <TextBlock Text="&#xF419;"
                                       FontFamily="{StaticResource FontIcons}"
                                       FontSize="14"/>
                        </Button>
                    </Grid>
                </Grid>

                <!-- RIGHT COLUMN -->
                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*" Margin="10,10,16,12">
                    <!-- STATUS CARD -->
                    <Border Grid.Row="0"
                            Name="TitleBar"
                            Background="{StaticResource BrBgCard}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            Margin="0,6,0,10"
                            Padding="16,10">
                        <StackPanel>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{DynamicResource TxtOptiStatus}"
                                               FontSize="{StaticResource FontSizeBody}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource BrTextSecondary}"/>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Name="StatusIndicator"
                                                 Width="10" Height="10"
                                                 Margin="0,0,10,0"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Name="TxtStatus"
                                                   Text="Installed"
                                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BrTextPrimary}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Name="TxtVersion"
                                                   Text=""
                                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Name="BtnClose"
                                        Classes="IconBtn"
                                        VerticalAlignment="Top"
                                        Click="BtnClose_Click">
                                    <TextBlock Text="{OnPlatform '&#xE711;', Linux='✕'}"
                                               FontFamily="{OnPlatform 'Segoe Fluent Icons, Segoe MDL2 Assets, Segoe UI', Linux='sans-serif'}"
                                               FontSize="12"/>
                                </Button>
                            </Grid>

                        <!-- PROGRESS BAR (Oculto por defecto, dentro del Status Card) -->
                        <Border Name="BdProgress" Margin="0,12,0,0" IsVisible="False">
                            <StackPanel>
                                <TextBlock Name="TxtProgressState" Text="Downloading OptiScaler..."
                                           Foreground="{StaticResource BrTextPrimary}" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ProgressBar Name="PrgDownload" Height="6" Minimum="0" Maximum="100" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    </Border>

                    <!-- DETECTED COMPONENTS -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrBgSurface}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            Padding="12,10"
                            Margin="0,0,0,10">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{DynamicResource TxtDetectedComponents}"
                                       FontSize="{StaticResource FontSizeBody}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource BrTextSecondary}"/>
                            <ListBox Name="LstComponents"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     IsHitTestVisible="False">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource BrBgCard}"
                                                BorderBrush="{StaticResource BrBorderSubtle}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource RadiusPill}"
                                                Padding="10,6"
                                                Margin="0,0,6,6">
                                            <TextBlock Text="{Binding}" Foreground="{StaticResource BrTextPrimary}" FontSize="{StaticResource FontSizeCaption}"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <!-- EasyAntiCheat Detection -->
                            <Border Name="EasyAntiCheat"
                                    Background="{StaticResource BrBgCard}"
                                    BorderBrush="{StaticResource BrBorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusLarge}"
                                    Padding="16,12"
                                    Margin="0,8,0,0"
                                    IsVisible="False">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="⚠ Anti Cheat Detected"
                                                   Foreground="{StaticResource BrTextPrimary}"
                                                   FontWeight="SemiBold"
                                                   FontSize="{StaticResource FontSizeBody}"/>
                                        <TextBlock Text="This game uses anti-cheat protection, use OptiScaler at your own risk"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontSize="{StaticResource FontSizeCaption}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>



                    <!-- COMPATIBILITY INFO -->
                    <Border Grid.Row="2"
                            Background="{StaticResource BrBgSurface}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            Padding="12,10"
                            Margin="0,0,0,10">
                        <Grid RowDefinitions="Auto,Auto">
                            <!-- Header row -->
                            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="0,0,0,4">
                                <TextBlock Grid.Column="0"
                                           Text="Compatibility"
                                           FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource BrTextSecondary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Name="TxtCompatLoading"
                                           Text="  Checking..."
                                           Foreground="{StaticResource BrTextSecondary}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="2"
                                        Name="BtnCompatWiki"
                                        Classes="BtnBase"
                                        Padding="8,4"
                                        Margin="0,0,6,0"
                                        IsVisible="False"
                                        Click="BtnCompatWiki_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="&#xF1A4;"
                                                   FontFamily="{StaticResource FontIcons}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Wiki" FontSize="11" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="3"
                                        Name="BtnCompatApply"
                                        Classes="BtnPrimary"
                                        Padding="8,4"
                                        IsVisible="False"
                                        Click="BtnCompatApply_Click">
                                    <TextBlock Text="Apply Settings" FontSize="11"/>
                                </Button>
                            </Grid>

                            <!-- Content area -->
                            <StackPanel Grid.Row="1" Spacing="6">
                                <!-- Found state -->
                                <StackPanel Name="PnlCompatFound" IsVisible="False" Spacing="5">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <!-- Status badge -->
                                        <Border Name="BdCompatStatus"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource RadiusPill}"
                                                Padding="8,3">
                                            <TextBlock Name="TxtCompatStatus"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <!-- Upscaler input chips -->
                                        <ItemsControl Name="LstCompatInputs">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource BrBgCard}"
                                                            BorderBrush="{StaticResource BrBorderSubtle}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource RadiusPill}"
                                                            Padding="8,3"
                                                            Margin="0,0,4,0">
                                                        <TextBlock Text="{Binding}"
                                                                   Foreground="{StaticResource BrTextPrimary}"
                                                                   FontSize="11"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <!-- OptiPatcher badge -->
                                        <Border Name="BdCompatOptiPatcher"
                                                Background="#1A8B73F8"
                                                BorderBrush="{StaticResource BrAccent}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource RadiusPill}"
                                                Padding="8,3"
                                                IsVisible="False">
                                            <TextBlock Text="✨ OptiPatcher"
                                                       Foreground="{StaticResource BrAccent}"
                                                       FontSize="11"/>
                                        </Border>
                                    </StackPanel>
                                    <!-- Notes -->
                                    <TextBlock Name="TxtCompatNotes"
                                               TextWrapping="Wrap"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               MaxLines="3"
                                               IsVisible="False"/>
                                </StackPanel>
                                <!-- Not found state -->
                                <TextBlock Name="TxtCompatNotFound"
                                           Text="No compatibility entry found for this game."
                                           Foreground="{StaticResource BrTextSecondary}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           IsVisible="False"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CONFIG + ACTIONS -->
                    <Border Grid.Row="3"
                            VerticalAlignment="Stretch"
                            Background="{StaticResource BrBgDeep}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            Padding="14,12">
                        <StackPanel Name="PnlInstallOptions" Spacing="0">
                            <!-- Info panel -->
                            <Border Name="BetaInfoPanel"
                                    Background="{StaticResource BrBgElevated}"
                                    BorderBrush="#4A90E2"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,6"
                                    Margin="0,0,0,10"
                                    IsVisible="False">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="&#xF4A4;"
                                               FontFamily="{StaticResource FontIcons}"
                                               Foreground="#4A90E2"
                                               FontSize="16"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource TxtBetaIncludesComponents}"
                                               Foreground="#4A90E2"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Options + Actions (3 columns × 5 rows) -->
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  ColumnDefinitions="*,*,*"
                                  RowSpacing="10"
                                  ColumnSpacing="12">

                                <!-- Row 0, Col 0 : OptiScaler version -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{DynamicResource TxtVersionLbl}"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                    <Grid Name="GridOptiTabs" ColumnDefinitions="*,*">
                                        <Button Name="BtnOptiStable"
                                                Grid.Column="0"
                                                Content="Stable"
                                                Classes="BtnPrimary"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="11"
                                                Padding="8,5"
                                                Margin="0,0,2,0"
                                                Click="BtnOptiStable_Click"/>
                                        <Button Name="BtnOptiBeta"
                                                Grid.Column="1"
                                                Content="Beta"
                                                Classes="BtnSecondary"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="11"
                                                Padding="8,5"
                                                Margin="2,0,0,0"
                                                Click="BtnOptiBeta_Click"/>
                                        <Button Name="BtnOptiCustom"
                                                Grid.Column="2"
                                                Content="Custom"
                                                Classes="BtnSecondary"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="11"
                                                Padding="8,5"
                                                Margin="2,0,0,0"
                                                IsVisible="False"
                                                Click="BtnOptiCustom_Click"/>
                                    </Grid>
                                    <ComboBox Name="CmbOptiVersion"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              SelectedIndex="0"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 1, Col 0 : Injection method -->
                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <TextBlock Text="{DynamicResource TxtInjectionLbl}"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                    <ComboBox Name="CmbInjectionMethod"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              SelectedIndex="0"
                                              VerticalContentAlignment="Center">
                                        <ComboBoxItem Content="dxgi.dll"     Tag="dxgi.dll"/>
                                        <ComboBoxItem Content="winmm.dll"    Tag="winmm.dll"/>
                                        <ComboBoxItem Content="d3d12.dll"    Tag="d3d12.dll"/>
                                        <ComboBoxItem Content="dbghelp.dll"  Tag="dbghelp.dll"/>
                                        <ComboBoxItem Content="version.dll"  Tag="version.dll"/>
                                        <ComboBoxItem Content="wininet.dll"  Tag="wininet.dll"/>
                                        <ComboBoxItem Content="winhttp.dll"  Tag="winhttp.dll"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Row 2, Col 0 : Profile selector -->
                                <StackPanel Grid.Row="2" Grid.Column="0">
                                    <TextBlock Text="Profile"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                    <ComboBox Name="CmbProfile"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 0, Col 1 : FSR4 INT8 -->
                                <StackPanel Grid.Row="0" Grid.Column="1">
                                    <TextBlock Text="FSR4 INT8"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Margin="0,32,0,0"/>
                                    <ComboBox Name="CmbExtrasVersion"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              Padding="8,0,24,0"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 1, Col 1 : OptiPatcher -->
                                <StackPanel Grid.Row="1" Grid.Column="1">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{DynamicResource TxtOptiPatcherLbl}"
                                                   Foreground="{StaticResource BrTextSecondary}"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{StaticResource BrBgElevated}"
                                                BorderBrush="{StaticResource BrBorderSubtle}"
                                                BorderThickness="1" CornerRadius="8"
                                                Width="16" Height="16"
                                                ToolTip.ShowDelay="100" Cursor="Help"
                                                ToolTip.Tip="{DynamicResource TxtOptiPatcherTooltip}">
                                            <TextBlock Text="?" Foreground="{StaticResource BrTextSecondary}"
                                                       FontSize="10" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Margin="0,-1,0,0"/>
                                        </Border>
                                    </StackPanel>
                                    <ComboBox Name="CmbOptiPatcherVersion"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              Padding="8,0,24,0"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 0, Col 2 : Fakenvapi version selector -->
                                <StackPanel Grid.Row="0" Grid.Column="2">
                                    <TextBlock Text="Fakenvapi"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Margin="0,32,0,0"/>
                                    <ComboBox Name="CmbFakenvapiVersion"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              Padding="8,0,24,0"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 1, Col 2 : NukemFG version selector -->
                                <StackPanel Grid.Row="1" Grid.Column="2">
                                    <TextBlock Text="NukemFG"
                                               Foreground="{StaticResource BrTextSecondary}"
                                               FontSize="{StaticResource FontSizeCaption}"/>
                                    <ComboBox Name="CmbNukemFGVersion"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Stretch"
                                              Classes="BtnSelector"
                                              Padding="8,0,24,0"
                                              HorizontalContentAlignment="Left"
                                              VerticalContentAlignment="Center"/>
                                </StackPanel>

                                <!-- Row 3, Col 2 : Uninstall button -->
                                <Button Name="BtnUninstall"
                                        Grid.Row="3" Grid.Column="2"
                                        Content="{DynamicResource TxtUninstall}"
                                        Classes="BtnDanger"
                                        Padding="14,7"
                                        HorizontalAlignment="Right"
                                        IsVisible="False"
                                        Click="BtnUninstall_Click"/>

                                <!-- Row 4, all columns : Install buttons right-aligned, Cleanup left-aligned -->
                                <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3">
                                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Left">
                                        <!-- Cleanup button — left side -->
                                        <Button Name="BtnFolderCleanup"
                                                Content="{DynamicResource TxtFolderCleanup}"
                                                Classes="BtnBase"
                                                Padding="14,7"
                                                Click="BtnFolderCleanup_Click"/>

                                        <!-- View Logs button -->
                                        <Button Name="BtnViewLogs"
                                                Content="View Logs"
                                                Classes="BtnBase"
                                                Padding="14,7"
                                                IsVisible="False"
                                                Click="BtnViewLogs_Click"/>
                                    </StackPanel>

                                    <!-- Install buttons — right side -->
                                    <StackPanel Name="InstallBtnGroup"
                                                Orientation="Horizontal" Spacing="10"
                                                HorizontalAlignment="Right">
                                        <Button Name="BtnInstallManual"
                                                Content="{DynamicResource TxtBtnManualInstall}"
                                                Classes="BtnSuccess"
                                                Padding="16,8"
                                                Click="BtnInstallManual_Click"/>
                                        <Button Name="BtnInstall"
                                                Content="{DynamicResource TxtInstallOpti}"
                                                Classes="BtnSuccess"
                                                Padding="16,8"
                                                Click="BtnInstall_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- COMPATIBILITY APPLY SETTINGS MODAL -->
                <Grid Name="BdCompatApplyModal" Grid.ColumnSpan="2" Background="#80000000" IsVisible="False" ZIndex="25">
                    <Border Background="{StaticResource BrBgElevated}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="24,20"
                            MaxWidth="500">
                        <StackPanel Spacing="0">
                            <TextBlock Text="Apply Compatibility Settings"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BrTextPrimary}"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="The following INI settings will be applied:"
                                       Foreground="{StaticResource BrTextSecondary}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="0,0,0,8"/>
                            <Border Background="{StaticResource BrBgSurface}"
                                    BorderBrush="{StaticResource BrBorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="12,8"
                                    Margin="0,0,0,16">
                                <ItemsControl Name="LstCompatSettings">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{StaticResource BrTextPrimary}"
                                                       FontFamily="Consolas, Courier New, monospace"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                            <TextBlock Text="Settings are placed in the [Upscalers] section. You can rearrange them in the Profile Editor."
                                       Foreground="{StaticResource BrTextSecondary}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Name="BtnCompatApplyCancel"
                                        Content="Cancel"
                                        Classes="BtnBase"
                                        Padding="16,8"
                                        Click="BtnCompatApplyCancel_Click"/>
                                <Button Name="BtnCompatApplyMerge"
                                        Content="Merge into Active Profile"
                                        Classes="BtnBase"
                                        Padding="16,8"
                                        Click="BtnCompatApplyMerge_Click"/>
                                <Button Name="BtnCompatApplyCreate"
                                        Content="Create New Profile"
                                        Classes="BtnPrimary"
                                        Padding="16,8"
                                        Click="BtnCompatApplyCreate_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- TOAST NOTIFICATION -->
                <Border Name="BdToast"
                        Grid.ColumnSpan="2"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Background="{StaticResource BrBgElevated}"
                        BorderBrush="{StaticResource BrAccent}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusMedium}"
                        BoxShadow="0 6 16 0 #80000000"
                        Margin="0,0,36,80"
                        Padding="16,10"
                        IsVisible="False"
                        ZIndex="100">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Name="TxtToastIcon" Text="&#x2713;" Foreground="{StaticResource BrAccent}" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Name="TxtToastMessage" Text="{DynamicResource TxtToastSuccess}" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- FOLDER CLEANUP CONFIRMATION MODAL -->
                <!-- CORRUPT INSTALL DETECTED MODAL -->
                <Grid Name="BdConfirmCorruptInstall" Grid.ColumnSpan="2" Background="#80000000" IsVisible="False" ZIndex="22">
                    <Border Background="{StaticResource BrBgElevated}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="24,24,24,20"
                            MaxWidth="600">
                        <StackPanel Spacing="0">
                            <!-- Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="&#x26A0;" Foreground="{StaticResource BrAccentWarm}" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource TxtCorruptInstallTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Description -->
                            <TextBlock Text="{DynamicResource TxtCorruptInstallMsg}"
                                       Foreground="{StaticResource BrTextSecondary}" FontSize="{StaticResource FontSizeBody}"
                                       TextWrapping="Wrap" Margin="0,0,0,20"/>

                            <!-- Action buttons: Cancel | Clean then Install | Continue anyway -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                                <Button Name="BtnCorruptCancel"   Content="{DynamicResource TxtCancel}"               Classes="BtnBase"   Padding="16,8" Click="BtnCorruptCancel_Click"/>
                                <Button Name="BtnCorruptClean"    Content="{DynamicResource TxtCorruptInstallClean}"   Classes="BtnDanger" Padding="16,8" Click="BtnCorruptClean_Click"/>
                                <Button Name="BtnCorruptContinue" Content="{DynamicResource TxtCorruptInstallContinue}" Classes="BtnBase"  Padding="16,8" Click="BtnCorruptContinue_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Name="BdConfirmFolderCleanup" Grid.ColumnSpan="2" Background="#80000000" IsVisible="False" ZIndex="21">
                    <Border Background="{StaticResource BrBgElevated}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="24,24,24,20"
                            MaxWidth="600">
                        <StackPanel Spacing="0">
                            <!-- Title -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="&#x26A0;" Foreground="{StaticResource BrAccentWarm}" FontSize="22" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource TxtFolderCleanupTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Main description -->
                            <TextBlock Text="{DynamicResource TxtFolderCleanupMsg}"
                                       Foreground="{StaticResource BrTextSecondary}" FontSize="{StaticResource FontSizeBody}"
                                       TextWrapping="Wrap" Margin="0,0,0,16"/>

                            <!-- Sensitive files section -->
                            <Border Background="{StaticResource BrBgSurface}"
                                    BorderBrush="{StaticResource BrBorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Padding="12,10"
                                    Margin="0,0,0,8">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{DynamicResource TxtFolderCleanupSensitiveHeader}"
                                               FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{StaticResource BrAccentWarm}" Margin="0,0,0,2"/>
                                    <TextBlock Text="{DynamicResource TxtFolderCleanupSensitiveNote}"
                                               Foreground="{StaticResource BrTextSecondary}" FontSize="{StaticResource FontSizeCaption}"
                                               TextWrapping="Wrap" Margin="0,0,0,8"/>

                                    <!-- Select All toggle -->
                                    <CheckBox Name="ChkSensitiveSelectAll"
                                              Content="Select / Deselect all"
                                              FontSize="{StaticResource FontSizeCaption}"
                                              Foreground="{StaticResource BrTextSecondary}"
                                              IsChecked="False"
                                              Margin="0,0,0,4"
                                              Click="ChkSensitiveSelectAll_Click"/>

                                    <!-- Per-file checkboxes — two-column grid (unchecked by default) -->
                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                        <CheckBox Grid.Column="0" Grid.Row="0" Name="ChkSensitive_amd_fidelityfx_dx12"    Content="amd_fidelityfx_dx12.dll"             IsChecked="False" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextPrimary}"/>
                                        <CheckBox Grid.Column="1" Grid.Row="0" Name="ChkSensitive_amd_fidelityfx_fg_dx12" Content="amd_fidelityfx_framegeneration_dx12.dll" IsChecked="False" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextPrimary}"/>
                                        <CheckBox Grid.Column="0" Grid.Row="1" Name="ChkSensitive_amd_fidelityfx_vk"      Content="amd_fidelityfx_vk.dll"               IsChecked="False" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextPrimary}"/>
                                        <CheckBox Grid.Column="1" Grid.Row="1" Name="ChkSensitive_dxgi"                   Content="dxgi.dll"                            IsChecked="False" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextPrimary}"/>
                                        <CheckBox Grid.Column="0" Grid.Row="2" Name="ChkSensitive_libxell"                Content="libxell.dll"                         IsChecked="False" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextPrimary}"/>
                                        <CheckBox Grid.Column="1" Grid.Row="2" Name="ChkSensitive_libxess"                Content="libxess.dll"                         IsChecked="False" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextPrimary}"/>
                                        <CheckBox Grid.Column="0" Grid.Row="3" Name="ChkSensitive_libxess_dx11"           Content="libxess_dx11.dll"                    IsChecked="False" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextPrimary}"/>
                                        <CheckBox Grid.Column="1" Grid.Row="3" Name="ChkSensitive_libxess_fg"             Content="libxess_fg.dll"                      IsChecked="False" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource BrTextPrimary}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button Name="BtnConfirmFolderCleanupNo" Content="{DynamicResource TxtCancel}" Classes="BtnBase" Padding="16,8" Margin="0,0,10,0" Click="BtnConfirmFolderCleanupNo_Click"/>
                                <Button Name="BtnConfirmFolderCleanupYes" Content="{DynamicResource TxtFolderCleanup}" Classes="BtnDanger" Padding="16,8" Click="BtnConfirmFolderCleanupYes_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- UNINSTALL CONFIRMATION MODAL -->
                <Grid Name="BdConfirmUninstall" Grid.ColumnSpan="2" Background="#80000000" IsVisible="False" ZIndex="20">
                    <Border Background="{StaticResource BrBgElevated}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="24,24,24,20"
                            MaxWidth="400">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="!" Foreground="{StaticResource BrAccentWarm}" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource TxtConfirmUninstallTitle}" FontSize="{StaticResource FontSizeSubtitle}" FontWeight="Bold" Foreground="{StaticResource BrTextPrimary}" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Message -->
                            <TextBlock Text="{DynamicResource TxtConfirmUninstallMsg}"
                                       Foreground="{StaticResource BrTextSecondary}" FontSize="{StaticResource FontSizeBody}"
                                       TextWrapping="Wrap" Margin="0,0,0,24"/>

                            <!-- Buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Name="BtnConfirmUninstallNo" Content="{DynamicResource TxtCancel}" Classes="BtnBase" Padding="16,8" Margin="0,0,10,0" Click="BtnConfirmUninstallNo_Click"/>
                                <Button Name="BtnConfirmUninstallYes" Content="{DynamicResource TxtUninstall}" Classes="BtnDanger" Padding="16,8" Click="BtnConfirmUninstallYes_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- COVER IMAGE MODAL -->
                <Grid Name="BdCoverModal" Grid.ColumnSpan="2" Background="#A0000000" IsVisible="False" ZIndex="30">
                    <Border Background="{StaticResource BrBgElevated}"
                            BorderBrush="{StaticResource BrBorderSubtle}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusLarge}"
                            BoxShadow="0 8 32 0 #80000000"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="24"
                            Width="480">
                        <StackPanel Spacing="16">
                            <!-- Encabezado -->
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Border Background="{StaticResource BrBgSurface}" Width="36" Height="36" CornerRadius="{StaticResource RadiusMedium}">
                                        <TextBlock Text="&#xE726;"
                                               FontFamily="{StaticResource FontIcons}"
                                               FontSize="18"
                                               Foreground="{StaticResource BrAccent}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource TxtCoverUpdateTitle}"
                                               FontSize="{StaticResource FontSizeSubtitle}"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource BrTextPrimary}"/>
                                    <TextBlock Text="{DynamicResource TxtCoverUpdateDesc}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource BrTextSecondary}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Área de preview -->
                            <Border Background="{StaticResource BrBgSurface}"
                                    BorderBrush="{StaticResource BrBorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource RadiusMedium}"
                                    Height="250"
                                    ClipToBounds="True">
                                <Grid>
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8">
                                        <TextBlock Text="&#xE726;" FontFamily="{StaticResource FontIcons}" FontSize="32" Foreground="{StaticResource BrTextSecondary}" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{DynamicResource TxtPreviewUnavailable}" Foreground="{StaticResource BrTextSecondary}" FontWeight="Medium"/>
                                    </StackPanel>
                                    <Image Name="ImgCoverPreview" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        <!-- Injector selector row -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="{DynamicResource TxtInjectionLbl}"
                                       Foreground="{StaticResource BrTextSecondary}"
                                       VerticalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}"
                                       Width="65"/>
                            <ComboBox Name="CmbInjectionMethodCover"
                                      Width="220"
                                      Classes="BtnSelector"
                                      Padding="8,0,24,0"
                                      SelectedIndex="0"
                                      HorizontalContentAlignment="Left"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem Content="dxgi.dll"     Tag="dxgi.dll"/>
                                <ComboBoxItem Content="winmm.dll"    Tag="winmm.dll"/>
                                <ComboBoxItem Content="d3d12.dll"    Tag="d3d12.dll"/>
                                <ComboBoxItem Content="dbghelp.dll"  Tag="dbghelp.dll"/>
                                <ComboBoxItem Content="version.dll"  Tag="version.dll"/>
                                <ComboBoxItem Content="wininet.dll"  Tag="wininet.dll"/>
                                <ComboBoxItem Content="winhttp.dll"  Tag="winhttp.dll"/>
                            </ComboBox>
                            <Border Background="{StaticResource BrBgElevated}"
                                    BorderBrush="{StaticResource BrBorderSubtle}"
                                    BorderThickness="1" CornerRadius="8"
                                    Width="16" Height="16"
                                    Margin="10,0,0,0"
                                    ToolTip.ShowDelay="100" Cursor="Help"
                                    ToolTip.Tip="{DynamicResource TxtTooltipInjectionMethod}">
                                <TextBlock Text="?" Foreground="{StaticResource BrTextSecondary}"
                                            FontSize="10" FontWeight="Bold"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Margin="0,-1,0,0"/>
                            </Border>
                        </StackPanel>

                        <!-- Action buttons -->
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                            <Button Name="BtnCoverReset" Grid.Column="0" Classes="BtnBase" Padding="14,8" Click="BtnCoverReset_Click" ToolTip.Tip="{DynamicResource TxtCoverRestoreTooltip}">
                                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <TextBlock Text="&#xF1A0;"
                                               FontFamily="{StaticResource FontIcons}"
                                               VerticalAlignment="Center"
                                               FontSize="12"/>
                                    <TextBlock Text="{DynamicResource TxtRestore}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Name="BtnCoverSelect" Grid.Column="2" Content="{DynamicResource TxtBrowse}" Classes="BtnBase" Padding="14,8" Margin="0,0,8,0" Click="BtnCoverSelect_Click"/>
                            <Button Name="BtnCoverCancel" Grid.Column="3" Content="{DynamicResource TxtCancel}" Classes="BtnBase" Padding="14,8" Margin="0,0,8,0" Click="BtnCoverCancel_Click"/>
                            <Button Name="BtnCoverApply" Grid.Column="4" Content="{DynamicResource TxtApply}" Classes="BtnSuccess" Padding="20,8" Click="BtnCoverApply_Click"/>
                        </Grid>
                    </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- Dim backdrop shown behind child dialogs -->
        <Border Name="DimOverlay"
                CornerRadius="12"
                Background="#A0000000"
                IsVisible="False"
                ZIndex="9999"/>
    </Panel>
</Window>
