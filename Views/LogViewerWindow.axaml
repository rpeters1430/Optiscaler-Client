<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OptiscalerClient.Views.LogViewerWindow"
        Title="OptiScaler Logs"
        Width="800" Height="550"
        MinWidth="550" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BrBgBase}"
        RequestedThemeVariant="Dark">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <!-- Top Toolbar -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,12">
            <ComboBox Grid.Column="0" Name="CmbLogFile" HorizontalAlignment="Left" Width="240"
                      SelectedIndex="0" SelectionChanged="CmbLogFile_SelectionChanged">
                <!-- Items populated dynamically in code-behind -->
            </ComboBox>

            <Button Grid.Column="1" Name="BtnRefresh" Content="Refresh" Margin="10,0,0,0" Padding="12,6" Click="BtnRefresh_Click">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="&#xF4A5;" FontFamily="{StaticResource FontIcons}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="Refresh" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Name="BtnCopy" Content="Copy All" Margin="8,0,0,0" Padding="12,6" Click="BtnCopy_Click">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="&#xF2C5;" FontFamily="{StaticResource FontIcons}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="Copy All" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="3" Name="BtnOpenDir" Content="Open Folder" Margin="8,0,0,0" Padding="12,6" Click="BtnOpenDir_Click">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="&#xF368;" FontFamily="{StaticResource FontIcons}" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="Open Folder" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Log Content -->
        <Border Grid.Row="1" Background="{StaticResource BrBgDeep}" BorderBrush="{StaticResource BrBorderSubtle}"
                BorderThickness="1" CornerRadius="{StaticResource RadiusMedium}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <SelectableTextBlock Name="TxtLogContent" FontFamily="Consolas, Courier New, monospace" FontSize="12"
                                     Foreground="#A8A8C4" Padding="12" TextWrapping="NoWrap"
                                     VerticalAlignment="Top" HorizontalAlignment="Left"/>
            </ScrollViewer>
        </Border>

        <!-- Footer / Operations -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <TextBlock Grid.Column="0" Name="TxtLogStatus" Foreground="{StaticResource BrTextSecondary}"
                       FontSize="{StaticResource FontSizeCaption}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Name="BtnClearLog" Content="Clear Log" Margin="10,0,0,0" Padding="12,6" Click="BtnClearLog_Click">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="&#xF35D;" FontFamily="{StaticResource FontIcons}" FontSize="12" VerticalAlignment="Center" Foreground="{StaticResource BrError}"/>
                    <TextBlock Text="Clear Log File" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
